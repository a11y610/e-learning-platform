PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?appName=<appName>
JWT_SECRET=change-this-to-a-long-random-secret

# Email Configuration (Gmail SMTP)
# IMPORTANT: Both EMAIL_USER and EMAIL_PASSWORD are REQUIRED for OTP sending to work.
#
# 1. EMAIL_USER  – your real Gmail address (e.g. yourname@gmail.com).
#    This address is also used as the sender address; Gmail SMTP requires
#    the "from" to match the authenticated account.
#
# 2. EMAIL_PASSWORD – a Gmail App Password (NOT your regular account password).
#    Steps to generate one:
#      a. Enable 2-Step Verification on your Google Account.
#      b. Go to: Google Account → Security → 2-Step Verification → App passwords.
#      c. Select "Mail" and your device, then click "Generate".
#      d. Copy the 16-character password and paste it below (no spaces).
EMAIL_USER=your-gmail-address@gmail.com
EMAIL_PASSWORD=your-16-char-app-password
