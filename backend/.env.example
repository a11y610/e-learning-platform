PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?appName=<appName>
JWT_SECRET=change-this-to-a-long-random-secret

# Email Configuration (Gmail SMTP)
# 1. Use a real Gmail address for EMAIL_USER.
# 2. For EMAIL_PASSWORD, use a Gmail App Password (NOT your regular password):
#    - Go to: Google Account → Security → 2-Step Verification → App passwords
#    - Generate a password for "Mail" and paste it here.
EMAIL_USER=your-gmail-address@gmail.com
EMAIL_PASSWORD=your-16-char-app-password
EMAIL_FROM=noreply@elearning-platform.com
